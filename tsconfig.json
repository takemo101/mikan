{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"types": ["bun"],
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"noFallthroughCasesInSwitch": true,
		"noEmit": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"allowImportingTsExtensions": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"forceConsistentCasingInFileNames": true,
		"verbatimModuleSyntax": true,
		"baseUrl": ".",
		"paths": {
			"@mikan/browser": ["packages/browser/src/index.ts"],
			"@mikan/core": ["packages/core/src/index.ts"],
			"@mikan/github": ["packages/github/src/index.ts"],
			"@mikan/mcp": ["packages/mcp/src/index.ts"],
			"@mikan/project-config": ["packages/project-config/src/index.ts"],
			"@mikan/tui": ["packages/tui/src/index.ts"]
		}
	},
	"include": [
		"packages/*/src/**/*.ts",
		"packages/*/src/**/*.tsx",
		"packages/*/__tests__/**/*.ts",
		"packages/*/__tests__/**/*.tsx",
		"__tests__/**/*.ts"
	],
	"exclude": ["node_modules", "dist"]
}
